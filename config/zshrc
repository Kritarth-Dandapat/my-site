# Powerlevel10k instant prompt (keep near top; console input must go above this block)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# This file lives in my-site/config; p10k config is alongside it
export MY_SITE_CONFIG_DIR="$(cd "$(dirname "${(%):-%x}")" && pwd)"
export POWERLEVEL9K_CONFIG_FILE="$MY_SITE_CONFIG_DIR/p10k.zsh"

# Homebrew (PATH, completions, brew plugin)
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export PATH="$HOME/.local/bin:$PATH"

if command -v nvim >/dev/null; then
  export EDITOR="nvim"
  export VISUAL="nvim"
fi

# GNU nano from Homebrew (matches my-site/config/nanorc include paths)
if [[ -x /opt/homebrew/bin/nano ]]; then
  alias nano='/opt/homebrew/bin/nano'
fi

# Unicode prompt segments need UTF-8 in the terminal
export LANG="${LANG:-en_US.UTF-8}"

# Extra zsh completions from Homebrew (before Oh My Zsh runs compinit)
if command -v brew >/dev/null; then
  FPATH="$(brew --prefix)/share/zsh-completions:$FPATH"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 13

COMPLETION_WAITING_DOTS="true"

plugins=(
  git
  brew
  macos
  colored-man-pages
)

source "$ZSH/oh-my-zsh.sh"

# Tab completion: menu, colors, case-insensitive / partial matching
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors ''
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'l:|=* r:|=*'

setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY
HISTSIZE=50000
SAVEHIST=50000

# macOS ls colors
export CLICOLOR=1

# fzf: fuzzy finder (Ctrl+R = fuzzy history; **<Tab> = fuzzy path completion)
if command -v fzf >/dev/null; then
  eval "$(fzf --zsh)"
fi

# Inline predictions: history + completion engine (accept with → or Ctrl+F)
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
if [[ -r "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# Command syntax colors (must load after autosuggestions)
export ZSH_HIGHLIGHT_HIGHLIGHTERS_DIR="$(brew --prefix)/share/zsh-syntax-highlighting/highlighters"
if [[ -r "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
  source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

# Prompt: edit config/p10k.zsh or run `p10k configure` (writes POWERLEVEL9K_CONFIG_FILE)
[[ ! -f "$POWERLEVEL9K_CONFIG_FILE" ]] || source "$POWERLEVEL9K_CONFIG_FILE"
